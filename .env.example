# Mirror of bot/.env.example for convenience in repository root.
# Installer uses /opt/amnezia/bot/.env (generated from bot/.env.example).

# === Required ===
API_TOKEN=
ADMIN_ID=
ENCRYPTION_SECRET=
SERVER_PUBLIC_KEY=
SERVER_IP=

# === General ===
SERVER_NAME=My VPN
DB_PATH=vpn_bot.db
DOWNLOAD_URL=https://amnezia.org
SUPPORT_USERNAME=@support

# Optional fallback/rotation for encrypted data migration
ENCRYPTION_SECRET_FALLBACK=
ENCRYPTION_OLD_SECRETS=

# === AWG / Docker integration ===
DOCKER_CONTAINER=amnezia-awg2
WG_INTERFACE=awg0
PUBLIC_HOST=
IGNORE_PEERS=

# === Tariffs ===
STARS_PRICE_7_DAYS=15
STARS_PRICE_30_DAYS=50

# === Client/IP pool ===
VPN_SUBNET_PREFIX=10.8.1.
FIRST_CLIENT_OCTET=3
MAX_CLIENT_OCTET=254
CONFIGS_PER_USER=2
CLEANUP_INTERVAL_SECONDS=300
PENDING_KEY_TTL_SECONDS=900
PAYMENT_RETRY_DELAY_SECONDS=60

# === WireGuard/Amnezia client options ===
PRIMARY_DNS=1.1.1.1
SECONDARY_DNS=1.0.0.1
CLIENT_MTU=1376
PERSISTENT_KEEPALIVE=25
CLIENT_ALLOWED_IPS=0.0.0.0/0, ::/0

# === AWG anti-censorship params ===
AWG_JC=6
AWG_JMIN=10
AWG_JMAX=50
AWG_S1=37
AWG_S2=98
AWG_S3=47
AWG_S4=14
AWG_H1=1486401722-1692300209
AWG_H2=1696990121-1817276760
AWG_H3=1841833217-1995591429
AWG_H4=2109962185-2145796739
AWG_I1=<r 2><b 0x858000010001000000000669636c6f756403636f6d0000010001c00c000100010000105a00044d583737>
AWG_I2=
AWG_I3=
AWG_I4=
AWG_I5=
AWG_PROTOCOL_VERSION=2
AWG_TRANSPORT_PROTO=udp

# === Rate limits / retries / timeouts ===
PURCHASE_CLICK_COOLDOWN_SECONDS=2
PURCHASE_RATE_LIMIT_TTL_SECONDS=3600
ADMIN_COMMAND_COOLDOWN_SECONDS=2
DOCKER_RETRIES=3
DOCKER_RETRY_BASE_DELAY=0.5
DOCKER_TIMEOUT_SECONDS=20
AWG_PEERS_CACHE_TTL_SECONDS=5.0
