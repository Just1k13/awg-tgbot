# =========================================
# AWG Telegram Bot — example environment
# Скопируй в .env при ручной настройке.
# Для установки через awg-tgbot.sh большую часть значений
# можно оставить пустыми — скрипт и config.py сами подхватят/сгенерируют нужное.
# =========================================

# --- REQUIRED ---
# Токен Telegram-бота от @BotFather
API_TOKEN=

# Telegram user_id администратора
ADMIN_ID=

# Секрет для шифрования приватных данных в БД
# Можно оставить пустым при установке через awg-tgbot.sh:
# он будет сгенерирован автоматически.
ENCRYPTION_SECRET=

# --- SERVER / AWG ---
# Название сервера / конфигурации, которое увидит пользователь
SERVER_NAME=My VPN

# Публичный endpoint сервера в формате host:port
# Пример: 1.2.3.4:51820
# Если оставить пустым, проект попробует определить автоматически.
SERVER_IP=

# PublicKey сервера AWG
# Если оставить пустым, проект попробует определить автоматически из контейнера.
SERVER_PUBLIC_KEY=

# Имя Docker-контейнера с Amnezia WG / AWG
DOCKER_CONTAINER=amnezia-awg2

# Имя интерфейса внутри контейнера
WG_INTERFACE=awg0

# Путь до sqlite БД
DB_PATH=vpn_bot.db

# --- BOT / UI ---
# Ссылка на скачивание клиента Amnezia
DOWNLOAD_URL=https://amnezia.org

# Ник поддержки в Telegram. Можно оставить пустым —
# бот попробует использовать username администратора.
SUPPORT_USERNAME=

# --- PRICING ---
# Стоимость подписок в Telegram Stars
STARS_PRICE_7_DAYS=15
STARS_PRICE_30_DAYS=50

# --- NETWORK ---
VPN_SUBNET_PREFIX=10.8.1.
FIRST_CLIENT_OCTET=3
MAX_CLIENT_OCTET=254

# Количество конфигов на одного пользователя
CONFIGS_PER_USER=2

# Интервал фоновой очистки просроченных подписок, сек
CLEANUP_INTERVAL_SECONDS=300

PRIMARY_DNS=172.29.172.254
SECONDARY_DNS=1.0.0.1
CLIENT_MTU=1280
PERSISTENT_KEEPALIVE=25
CLIENT_ALLOWED_IPS=0.0.0.0/0, ::/0

# Список public key, которые нельзя удалять как orphan peer
# Несколько значений — через запятую
IGNORE_PEERS=

# --- LIMITS / SERVICE ---
PURCHASE_CLICK_COOLDOWN_SECONDS=2
PURCHASE_RATE_LIMIT_TTL_SECONDS=3600
ADMIN_COMMAND_COOLDOWN_SECONDS=2

DOCKER_RETRIES=3
DOCKER_RETRY_BASE_DELAY=0.5
DOCKER_TIMEOUT_SECONDS=20
AWG_PEERS_CACHE_TTL_SECONDS=5.0

# --- AMNEZIA WG ADVANCED ---
# Обычно менять не нужно, если у тебя уже есть рабочий AWG.
AWG_PROTOCOL_VERSION=2
AWG_TRANSPORT_PROTO=udp

AWG_JC=6
AWG_JMIN=10
AWG_JMAX=50
AWG_S1=37
AWG_S2=98
AWG_S3=47
AWG_S4=14

AWG_H1=1486401722-1692300209
AWG_H2=1696990121-1817276760
AWG_H3=1841833217-1995591429
AWG_H4=2109962185-2145796739

AWG_I1=<r 2><b 0x858000010001000000000669636c6f756403636f6d0000010001c00c000100010000105a00044d583737>
AWG_I2=
AWG_I3=
AWG_I4=
AWG_I5=
